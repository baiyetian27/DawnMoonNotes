<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
    Crescent moon using evenOdd fill:
    Outer circle (r=32, center x=54) + inner circle (r=20, center x=46)
    The overlap cancels out, leaving a right-side crescent.
    -->
    <path
        android:fillType="evenOdd"
        android:pathData="M54,22 A32,32 0 1,1 54,86 A32,32 0 1,1 54,22
                         M46,34 A20,20 0 1,1 46,74 A20,20 0 1,1 46,34"
        android:fillColor="#C084FC"/>

    <!-- Small star accent 1 (upper right) -->
    <path
        android:pathData="M74,36 m-3.5,0 a3.5,3.5 0 1,0 7,0 a3.5,3.5 0 1,0 -7,0"
        android:fillColor="#E2E0E7"
        android:fillAlpha="0.85"/>

    <!-- Small star accent 2 (mid right) -->
    <path
        android:pathData="M70,62 m-2.5,0 a2.5,2.5 0 1,0 5,0 a2.5,2.5 0 1,0 -5,0"
        android:fillColor="#E2E0E7"
        android:fillAlpha="0.55"/>
</vector>
