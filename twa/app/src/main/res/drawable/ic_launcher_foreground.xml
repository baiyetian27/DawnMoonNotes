<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
    Yellow crescent moon ("cheese" shape) using intersecting arcs:
    Two intersecting circles — the path traces the right side of the outer circle
    and returns along the right side of the inner circle, forming pointed tips.
    No evenOdd needed — works on all Android versions.
    Outer: center(54,54) r=31   Inner: center(38,54) r=23
    Intersection points: (32.5, 31.67) and (32.5, 76.33)
    -->
    <path
        android:pathData="M32.5,31.67
                         A31,31 0 1,1 32.5,76.33
                         A23,23 0 1,0 32.5,31.67
                         Z"
        android:fillColor="#F5C842"/>

    <!-- Four-pointed star 1 (upper left) -->
    <path
        android:pathData="M22,23 L23.5,26.5 L27,28 L23.5,29.5 L22,33 L20.5,29.5 L17,28 L20.5,26.5 Z"
        android:fillColor="#F5C842"/>

    <!-- Four-pointed star 2 (lower left, slightly smaller) -->
    <path
        android:pathData="M22,74 L23.2,76.8 L26,78 L23.2,79.2 L22,82 L20.8,79.2 L18,78 L20.8,76.8 Z"
        android:fillColor="#F5C842"/>
</vector>
